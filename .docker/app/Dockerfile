ARG DOCKER_IMAGE_VERSION=master
ARG DOCKER_SERVER_HOST
ARG DOCKER_PROJECT_PATH
ARG DOCKER_SERVER_PORT

FROM ${DOCKER_SERVER_HOST}:${DOCKER_SERVER_PORT}/${DOCKER_PROJECT_PATH}/node-dev:${DOCKER_IMAGE_VERSION} AS dev
# These ARGs should be after FROM or they will be empty
ARG YARN_INSTALL_CMD

WORKDIR /app
COPY . /app

RUN bash -c "${YARN_INSTALL_CMD}"

FROM ${DOCKER_SERVER_HOST}:${DOCKER_SERVER_PORT}/${DOCKER_PROJECT_PATH}/node-base:${DOCKER_IMAGE_VERSION}

COPY --from=dev /minter /minter
COPY --from=dev /app/dist /minter


WORKDIR /app

CMD ["mode", "app.js"]
